# Copie este archivo a .env y ajuste los valores para producción.
# Nunca suba .env al repositorio (debe estar en .gitignore).

# Supabase (proyecto clínica veterinaria)
VITE_SUPABASE_PROJECT_ID=su_project_id
VITE_SUPABASE_ANON_KEY=su_anon_key_publica

# Opcional: URL completa de las Edge Functions si usa un proxy o dominio custom
# VITE_SUPABASE_FUNCTIONS_URL=https://su_project_id.supabase.co/functions/v1/make-server-674cc941
