# ============================================================
#  GROOFLOW — Environment Variables
# ============================================================
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it's in .gitignore).
# In Vercel: set these in Project Settings → Environment Variables.
#
# ─── Backend selector ──────────────────────────────────────────
#
# Controls which backend adapter the app uses.
# Options: supabase | local
# Default: supabase
#
VITE_BACKEND=supabase

# ─── Supabase ─────────────────────────────────────────────────
#
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
#
VITE_SUPABASE_PROJECT_ID=sklseqxhhanuzsancbgn
VITE_SUPABASE_URL=https://sklseqxhhanuzsancbgn.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: only needed if you use a custom Functions URL
# VITE_SUPABASE_FUNCTIONS_URL=https://sklseqxhhanuzsancbgn.supabase.co/functions/v1/make-server-674cc941

# ─── Future backends (uncomment when implementing) ────────────
#
# REST API backend
# VITE_BACKEND=rest
# VITE_API_BASE_URL=https://api.mycompany.com/v1
# VITE_API_TOKEN=your_api_token_here
#
# Firebase backend
# VITE_BACKEND=firebase
# VITE_FIREBASE_API_KEY=...
# VITE_FIREBASE_PROJECT_ID=...
# VITE_FIREBASE_APP_ID=...
